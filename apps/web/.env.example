# Firebase Configuration (client) — from Firebase console > Project settings > Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=crush-f5352.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=crush-f5352
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=crush-f5352.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase App Check (REQUIRED: production callable/REST paths enforce App Check)
# reCAPTCHA site key registered for this Firebase app + environment.
NEXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_KEY=your_recaptcha_site_key
# Provider: recaptcha-enterprise (default, approved production provider) or recaptcha-v3.
NEXT_PUBLIC_FIREBASE_APPCHECK_PROVIDER=recaptcha-enterprise
# Optional: a debug token registered in the Firebase console. Honored ONLY in
# local development (NEXT_PUBLIC_APP_ENV=development); ignored in staging/prod.
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=
# App environment: development | staging | production (controls App Check
# enforcement strictness + debug-token gating). Falls back to NODE_ENV.
NEXT_PUBLIC_APP_ENV=development

# Web push (FCM) VAPID key — Firebase console > Cloud Messaging > Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Crush

# Feature Flags
NEXT_PUBLIC_ENABLE_PHONE_AUTH=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true

# Canonical REST API origin (added to CSP connect-src when set).
# Until a custom domain exists, *.cloudfunctions.net covers the default backend.
# NEXT_PUBLIC_API_ORIGIN=https://api.crush.app

# Monitoring (Sentry) — leave DSN empty to disable in local/dev.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_MONTHLY_PRICE_ID=price_monthly_id
STRIPE_QUARTERLY_PRICE_ID=price_quarterly_id
STRIPE_YEARLY_PRICE_ID=price_yearly_id

# Firebase Admin (REQUIRED for secure server-side writes, e.g. Stripe webhook).
# Use a FRESH crush-f5352 service-account key (see SECURITY_credential_rotation runbook).
# Option A: JSON service account (recommended)
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"project_id":"crush-f5352","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# Option B: Individual fields
# FIREBASE_ADMIN_PROJECT_ID=crush-f5352
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@crush-f5352.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
