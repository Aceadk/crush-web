# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase App Check (required: production callable/REST paths enforce App Check)
# reCAPTCHA site key registered for this Firebase app + environment.
NEXT_PUBLIC_FIREBASE_APPCHECK_RECAPTCHA_KEY=your_recaptcha_site_key
# Provider: recaptcha-enterprise (default, approved production provider) or recaptcha-v3.
NEXT_PUBLIC_FIREBASE_APPCHECK_PROVIDER=recaptcha-enterprise
# Optional: a debug token registered in the Firebase console. Honored ONLY in
# local development (NEXT_PUBLIC_APP_ENV=development); ignored in staging/prod.
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=
# App environment: development | staging | production (controls App Check
# enforcement strictness + debug-token gating). Falls back to NODE_ENV.
NEXT_PUBLIC_APP_ENV=development

# Web push (FCM) VAPID key
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_web_push_vapid_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Crush

# Monitoring (Sentry)
# Leave NEXT_PUBLIC_SENTRY_DSN empty to disable in local/dev.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=1
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_PHONE_AUTH=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=true

# API Configuration (if using custom backend)
# NEXT_PUBLIC_API_URL=https://api.yourapp.com
# Canonical REST API origin (set after the domain decision). When set, it is
# added to the CSP connect-src. Until then, *.cloudfunctions.net covers the
# default backend. Example: https://api.crush.app
# NEXT_PUBLIC_API_ORIGIN=

# Stripe (server-side)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_QUARTERLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Firebase Admin (required for secure server-side writes, e.g. Stripe webhook)
# Option A: JSON service account (recommended)
# FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
#
# Option B: Individual fields
# FIREBASE_ADMIN_PROJECT_ID=your_project_id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# Uptime monitor (GitHub Actions)
# Configure as repository secret:
# UPTIME_HEALTHCHECK_URL=https://crush-web-chi.vercel.app/api/health
